        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "b1c5fabe-fa6b-4ae9-9358-d11d4e2820c4",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "// تحقق أن الرد يحتوي على التوكن الجديد",
                  "if (jsonData.token && jsonData.refreshToken) {",
                  "    // هذه الخطوة هي الأهم: تحديث المتغيرات بالقيم الجديدة",
                  "    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.refreshToken);",
                  "    ",
                  "    console.log(\"New tokens updated successfully!\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
